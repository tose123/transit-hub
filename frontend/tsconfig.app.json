{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client", "@types/web-bluetooth"],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "components.json"]
}
